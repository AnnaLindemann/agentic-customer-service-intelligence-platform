{
  "name": "explainable-ai-email-decision-engine",
  "version": "0.1.0",
  "private": true,
  "description": "An AI-powered system that processes customer service emails through a deterministic pipeline and produces a grounded draft response with a full audit trace.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "start": "node dist/index.js",
    "validate:data": "tsc && node dist/scripts/validate-data.js",
    "build:index": "tsc && node dist/scripts/build-pdf-index.js",
    "check:retrieval": "tsc && node dist/scripts/check-retrieval.js",
    "smoke:llm": "tsc && node dist/scripts/smoke-llm.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.45.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
