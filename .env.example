NODE_ENV=development
PORT=3000

# --- LLM layer (Phase 6) ---
# Provider-neutral. The prototype uses Groq through the OpenAI SDK (OpenAI-compatible API),
# so switching to OpenAI later only means changing the base URL, key and model.
LLM_PROVIDER=groq

# Default model: GPT-OSS-120B via Groq. For local development use the cheaper fallback:
#   LLM_MODEL=openai/gpt-oss-20b
LLM_MODEL=openai/gpt-oss-120b
LLM_FALLBACK_MODEL=openai/gpt-oss-20b

# Groq endpoint and key (the OpenAI SDK points at this base URL).
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=

# Generation parameters.
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=800
LLM_TIMEOUT_MS=30000

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small

# Runtime
LOG_LEVEL=debug
